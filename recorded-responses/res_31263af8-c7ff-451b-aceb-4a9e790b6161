function ReplaceStrSearch(value) {
    value = value.toLowerCase();
    value = value.replace('<strong>', '');
    value = value.replace('</strong>', '');
    value = value.replace('<b>', '');
    value = value.replace('</b>', '');
    value = value.replace('/', '');
    value = value.replace('&', '');
    return value.replaceAll(' ', '+');
}

var suggestTimeout = null;
function GetQuickSearch(element, searchKeyword) {
    if (timeCnt > 0)
        return;
    if (searchKeyword.length >= 2) {
        if (Lkw != searchKeyword) {
            Lkw = searchKeyword;
            timeCnt++;

            clearTimeout(suggestTimeout);
            suggestTimeout = setTimeout(function () {
                $.ajax({
                    type: "GET",
                    headers:
                    {
                        'Cache-Control': 'no-cache, must-revalidate, max-age=0'
                    },
                    cache: true,
                    async: true,
                    dataType: "html",
                    url: "/Home/_SearchView?key=" + encodeURI($(element).val()),
                    success: function (data) {
                        timeCnt--;
                        if (data != null && data != "") {
                            $("div.quickSearch").html(data);
                            _QuickSearchEnable = true;
                            $(".quickSearch").show();
                        } else {
                            _QuickSearchEnable = false;
                            HideQuickSearch();
                        }
                    }
                });
            }, 300);
        }
        return;
    }
};

