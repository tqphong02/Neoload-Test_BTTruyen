function InitRecommendKw() {
    $('body').click(function () {
        $("div.quickSearch").hide();
    });

    $("div.quickSearch").click(function (event) {
        event.stopPropagation();
    });
    $(".txtSearchKey").click(function (event) {
        event.stopPropagation();
    });
    $(".txtSearchKey").click(function () {
        if ($(".txtSearchKey").val() != '') {
            if (Lkw != "" && _QuickSearchEnable == true) {
                $(".quickSearch").show();
            }
        }
    });

    $(".txtSearchKey").keyup(function (e) {
        KeyCode = e.keyCode;
        switch (KeyCode) {
            case 38:
                if (KwIndex > 0) {
                    KwIndex = KwIndex - 1;
                }
                else {
                    KwIndex = _KwListCount - 1;
                }

                SelectItem();
                return;
            case 40:
                if (KwIndex < _KwListCount - 1) { if (KwIndex < 1 && tempfirst == 0) { KwIndex = 0; tempfirst = 1; } else KwIndex = KwIndex + 1; } else KwIndex = 0;

                SelectItem();
                return;
            case 37:
                return;
            case 39:
                return;
            case 27: //ESC
                HideQuickSearch();
                _EventSearchEnable = true;
                return;
            case 32:
                _EventSearchEnable = true;
                return;
            case 13:
                valueSearch = $(".txtSearchKey").val();
                valueSearch = ReplaceStrSearch(valueSearch);

                window.location = domain + '/tim-truyen?keyword=' + valueSearch.replace("&", "%26");
                return;
        }

        var searchKeyword = $(".txtSearchKey").val();
        searchKeyword = searchKeyword.replace("&", "%26");

        if (searchKeyword == "") {
            HideQuickSearch();
            _EventSearchEnable = true;
            return;
        }
        GetQuickSearch(this, searchKeyword);
    });
};
