                showMark();
            },
            headers:
            {
                'Cache-Control': 'no-cache, must-revalidate, max-age=0'
            },
            cache: false,
            data: {
                Email: Email,
                Password: Password,
                captcha: $("#g-recaptcha-response").val()
            },
            success: function (data) {
                hideMark();
                if (data.result > 0) {
                    alert("Đăng nhập thành công");
                    location.href = returnUrl;
                }
                else {
                    alert(data.message);
                    console.log(data.message);
                }
