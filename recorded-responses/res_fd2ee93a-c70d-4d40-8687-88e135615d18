    }

    return false;
}

function GetOTP() {
    var Email = $("#Email").val();

    if (typeof (Email) == "undefined" || Email == null || Email == "") {
        alert("Vui lòng nhập email, Email không được để trống.");
        $("#Email").focus();
        return;
    }
    if (!validateEmail(Email)) {
        alert("Email không hợp lệ.");
        $("#Email").focus();
        return;
    }

    $("#Email").prop('disabled', true);
    $.ajax({
        type: "Post",
        url: "/request-otp",
        beforeSend: function (xhr) {
            showMark();
        },
        headers:
        {
            'Cache-Control': 'no-cache, must-revalidate, max-age=0'
        },
        cache: false,
        data: {
            Email: Email,
        },
        success: function (data) {
            hideMark();
            if (data.result > 0) {
                alert(data.message);
            }
            else {
                $("#Email").prop('disabled', true);
                alert(data.message);
                console.log(data.message);
            }
        },
        error: function (xhr) {
            hideMark();
            console.log(xhr);
            alert("Có lỗi xảy ra vui lòng thử lại");
        }
    });

}

