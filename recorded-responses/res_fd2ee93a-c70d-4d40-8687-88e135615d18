        }
    });
});


function register() {
    var url_string = window.location.href;
    var url = new URL(url_string);
    var returnUrl = url.searchParams.get("returnUrl");
    if (returnUrl == null || returnUrl == "") {
        returnUrl = window.location.origin;
    }

    var Email = $("#ctl00_mainContent_RegisterUser_CreateUserStepContainer_Email").val();
    var Password = $("#ctl00_mainContent_RegisterUser_CreateUserStepContainer_Password").val();
    var LastName = $("#ctl00_mainContent_RegisterUser_CreateUserStepContainer_txtLastName").val();

    if (typeof (Email) == "undefined" || Email == null || Email == "") {
        alert("Vui lòng nhập email, Email không được để trống.");
        $("#ctl00_mainContent_RegisterUser_CreateUserStepContainer_Email").focus();
        return;
    }
    if (!validateEmail(Email)) {
        alert("Email không hợp lệ.");
        $("#ctl00_mainContent_RegisterUser_CreateUserStepContainer_Email").focus();
        return;
    }
    if (typeof (Password) == "undefined" || Password == null || Password == "") {
        alert("Vui lòng nhập Mật khẩu");
        $("#ctl00_mainContent_RegisterUser_CreateUserStepContainer_Password").focus();
        return;
    }
    if (Password.length < 6) {
        alert("Mật khẩu phải lớn hơn 6 ký tự");
        $("#ctl00_mainContent_RegisterUser_CreateUserStepContainer_Password").focus();
        return;
    }
    if (Password == "123456" || Password == "123qwe" || Password == "abc123") {
        alert("Mật khẩu không được đặt quá đơn giản và dể bị hack");
        $("#ctl00_mainContent_RegisterUser_CreateUserStepContainer_Password").focus();
        return;
    }
    if (typeof (LastName) == "undefined" || LastName == null || LastName == "") {
        alert("Vui lòng nhập họ và tên");
        $("#ctl00_mainContent_RegisterUser_CreateUserStepContainer_txtLastName").focus();
        return;
    }
    if (isOk) {
        $.ajax({
            type: "Post",
            url: "/dang-ky",
            beforeSend: function (xhr) {
                showMark();
            },
            headers:
            {
                'Cache-Control': 'no-cache, must-revalidate, max-age=0'
            },
            cache: false,
            data: {
                Email: Email,
                Password: Password,
                FullName: LastName,
                captcha: $("#g-recaptcha-response").val()
            },
            success: function (data) {
                hideMark();
                if (data.result > 0) {
                    alert("Đăng ký thành công vui lòng đăng nhập để tiếp tục");
                    location.href = window.location.origin + "/dang-nhap?returnUrl=" + returnUrl;
                }
                else {
                    alert(data.message);
                    console.log(data.message);
                }
            },
            error: function (xhr) {
                hideMark();
                console.log(xhr);
                alert("Có lỗi xảy ra vui lòng thử lại");
            }
        })
    };
}

function validateEmail(email) {
    const re = /^(([^<>()[\]\\.,;:\s@\"]+(\.[^<>()[\]\\.,;:\s@\"]+)*)|(\".+\"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
    return re.test(email);
}
function login() {
    var url_string = window.location.href;
    var url = new URL(url_string);
    var returnUrl = url.searchParams.get("returnUrl");
