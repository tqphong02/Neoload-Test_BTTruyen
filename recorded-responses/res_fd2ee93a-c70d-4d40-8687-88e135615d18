$(function () {
    $("#ctl00_mainContent_login1_LoginCtrl_Register").click(function () {
        $("#rfvCaptcha").hide();
        if ($("#hfCaptcha").val() == "") {
            $("#rfvCaptcha").show();
        }
        else if ($("#hfCaptcha").val() != "" && $("#g-recaptcha-response").val() == "") {
            isOk = false;
            $("#rfvCaptcha").show();
        }
        else {
            register();
        }
    });
    $("#ctl00_mainContent_login1_LoginCtrl_Login").click(function () {
        $("#rfvCaptcha").hide();
        if ($("#hfCaptcha").val() == "") {
            $("#rfvCaptcha").show();
        }
        else if ($("#hfCaptcha").val() != "" && $("#g-recaptcha-response").val() == "") {
            isOk = false;
            $("#rfvCaptcha").show();
